<brls:AppletFrame
    headerHidden="true"
    footerHidden="false">
    <brls:Box
        width="100%"
        height="100%"
        axis="column"
        paddingTop="20"
        paddingLeft="20"
        paddingRight="20">

        <brls:Label
            id="feed/status"
            width="auto"
            height="auto"
            text="피드"
            fontSize="24"
            textColor="#FFFFFF"
            marginBottom="6" />

        <brls:Label
            id="feed/subtitle"
            width="auto"
            height="auto"
            text="A 재생 · Y 상세"
            fontSize="16"
            textColor="#D0D0D0"
            marginBottom="12" />

        <brls:ScrollingFrame
            id="feed/scroll"
            width="auto"
            grow="1.0">

            <brls:Box
                id="feed/grid"
                width="auto"
                height="auto"
                axis="column" />

        </brls:ScrollingFrame>
    </brls:Box>
</brls:AppletFrame>
