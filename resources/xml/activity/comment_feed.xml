<brls:AppletFrame
    headerHidden="true"
    footerHidden="false">
    <brls:Box
        width="100%"
        height="100%"
        axis="column"
        paddingTop="20"
        paddingLeft="20"
        paddingRight="20">
        <brls:Label
            id="comments/title"
            width="auto"
            height="auto"
            text="댓글"
            fontSize="24"
            textColor="#FFFFFF"
            marginBottom="8" />

        <brls:Label
            id="comments/subtitle"
            width="auto"
            height="auto"
            text="B 뒤로"
            fontSize="16"
            textColor="#B0B0B0"
            marginBottom="10" />

        <brls:ScrollingFrame
            width="auto"
            grow="1.0">
            <brls:Box
                id="comments/list"
                width="100%"
                height="auto"
                axis="column" />
        </brls:ScrollingFrame>
    </brls:Box>
</brls:AppletFrame>
